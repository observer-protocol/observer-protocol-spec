{
  "name": "@observer-protocol/sdk",
  "version": "0.2.0",
  "description": "Observer Protocol SDK - Agent identity, delegation, x402 verification, and chargeback prevention for the agentic economy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
