    "chargeback-prevention",
    "agentic-economy"
  ],
  "author": "Observer Protocol, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/observer-protocol/observer-protocol-spec.git",
    "directory": "sdk/typescript"
  },
  "homepage": "https://observerprotocol.org",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
