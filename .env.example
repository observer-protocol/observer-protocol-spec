# Observer Protocol — environment template
# Copy to .env and fill in values before starting the server.
# Never commit the filled-in .env file to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/observer_protocol

# ── Observer Protocol identity ────────────────────────────────────────────────
# OP's own DID (did:web method, no trailing slash).
OP_DID=did:web:observerprotocol.org

# OP's Ed25519 signing key — hex-encoded, exactly 64 hex characters (32 bytes).
# Generate with: python3 -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; k=Ed25519PrivateKey.generate(); print(k.private_bytes_raw().hex())"
OP_SIGNING_KEY=

# OP's Ed25519 public key — hex-encoded, exactly 64 hex characters (32 bytes).
# Derived from OP_SIGNING_KEY.
OP_PUBLIC_KEY=

# ── Trust / verification ──────────────────────────────────────────────────────
# Comma-separated list of trusted KYB provider DIDs.
TRUSTED_ISSUERS=

# ── Server ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
OP_ALLOWED_ORIGINS=https://observerprotocol.org,https://www.observerprotocol.org,https://agenticterminal.ai,https://www.agenticterminal.ai

# ── Workspace ─────────────────────────────────────────────────────────────────
# Relative or absolute path to the observer-protocol workspace root.
# Default is the current directory. Do NOT set to a user-specific home path.
OP_WORKSPACE_PATH=.

# ── Optional ──────────────────────────────────────────────────────────────────
# Helius API key for Solana RPC calls (optional).
# HELIUS_API_KEY=

# Timeout in seconds for outbound DID resolution requests.
# DID_RESOLVE_TIMEOUT_SECONDS=10
